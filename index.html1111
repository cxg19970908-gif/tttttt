<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>마음 일기 - 오늘의 감정 기록</title>
    <!-- Tailwind CSS CDN -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- 구글 폰트 (Noto Sans KR) -->
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@400;500;700&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Noto Sans KR', sans-serif;
            background-color: #f3f4f6;
        }
        .emoji-btn.active {
            transform: scale(1.2);
            background-color: #e0f2fe;
            border-color: #3b82f6;
        }
        .record-card {
            transition: transform 0.2s;
        }
        .record-card:hover {
            transform: translateY(-2px);
        }
    </style>
</head>
<body class="min-h-screen py-8 px-4">

    <div class="max-w-md mx-auto">
        <!-- 헤더 -->
        <header class="text-center mb-8">
            <h1 class="text-3xl font-bold text-gray-800">마음 일기 📝</h1>
            <p class="text-gray-500 mt-2">오늘의 감정을 한 줄로 기록해보세요.</p>
        </header>

        <!-- 입력 섹션 -->
        <div class="bg-white rounded-2xl shadow-md p-6 mb-8">
            <label class="block text-sm font-semibold text-gray-700 mb-3">지금 기분은 어떤가요?</label>
            <div class="flex justify-between mb-6" id="emojiContainer">
                <button type="button" onclick="selectEmoji(this, '😊')" class="emoji-btn text-3xl p-2 border-2 border-transparent rounded-xl transition-all hover:bg-gray-100">😊</button>
                <button type="button" onclick="selectEmoji(this, '😢')" class="emoji-btn text-3xl p-2 border-2 border-transparent rounded-xl transition-all hover:bg-gray-100">😢</button>
                <button type="button" onclick="selectEmoji(this, '😡')" class="emoji-btn text-3xl p-2 border-2 border-transparent rounded-xl transition-all hover:bg-gray-100">😡</button>
                <button type="button" onclick="selectEmoji(this, '😍')" class="emoji-btn text-3xl p-2 border-2 border-transparent rounded-xl transition-all hover:bg-gray-100">😍</button>
                <button type="button" onclick="selectEmoji(this, '😴')" class="emoji-btn text-3xl p-2 border-2 border-transparent rounded-xl transition-all hover:bg-gray-100">😴</button>
            </div>

            <label class="block text-sm font-semibold text-gray-700 mb-2">한 줄 감정</label>
            <input type="text" id="emotionInput" placeholder="여기에 내용을 입력하세요" 
                class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:outline-none focus:ring-2 focus:ring-blue-400 mb-4 transition-all">

            <button onclick="addRecord()" 
                class="w-full bg-blue-500 text-white font-bold py-3 rounded-lg hover:bg-blue-600 active:scale-95 transition-all shadow-lg shadow-blue-100">
                기록 저장하기
            </button>
        </div>

        <!-- 리스트 섹션 -->
        <div>
            <h2 class="text-lg font-bold text-gray-800 mb-4">나의 기록들</h2>
            <div id="recordList" class="space-y-4">
                <!-- 기록이 여기에 동적으로 추가됨 -->
            </div>
        </div>
    </div>

    <script>
        let selectedEmoji = '';
        let records = JSON.parse(localStorage.getItem('emotionRecords')) || [];

        // 초기 실행: 기존 데이터 렌더링
        window.onload = () => {
            renderRecords();
        };

        // 이모지 선택 함수
        function selectEmoji(element, emoji) {
            const buttons = document.querySelectorAll('.emoji-btn');
            buttons.forEach(btn => btn.classList.remove('active'));
            element.classList.add('active');
            selectedEmoji = emoji;
        }

        // 시간 포맷 함수 (예: 3월 23일 14:30)
        function formatCurrentTime() {
            const now = new Date();
            const month = now.getMonth() + 1;
            const day = now.getDate();
            const hours = String(now.getHours()).padStart(2, '0');
            const minutes = String(now.getMinutes()).padStart(2, '0');
            return `${month}월 ${day}일 ${hours}:${minutes}`;
        }

        // 기록 저장 함수
        function addRecord() {
            const input = document.getElementById('emotionInput');
            
            if (!selectedEmoji) {
                alert('이모지를 선택해 주세요!');
                return;
            }
            if (!input.value.trim()) {
                alert('내용을 입력해 주세요!');
                return;
            }

            const newRecord = {
                id: Date.now(),
                emoji: selectedEmoji,
                text: input.value,
                time: formatCurrentTime()
            };

            records.unshift(newRecord); // 최신 기록이 위로 오도록 추가
            saveToLocalStorage();
            renderRecords();

            // 입력창 초기화
            input.value = '';
            selectedEmoji = '';
            document.querySelectorAll('.emoji-btn').forEach(btn => btn.classList.remove('active'));
        }

        // 기록 삭제 함수
        function deleteRecord(id) {
            if(confirm('이 기록을 삭제하시겠습니까?')) {
                records = records.filter(record => record.id !== id);
                saveToLocalStorage();
                renderRecords();
            }
        }

        // LocalStorage 저장
        function saveToLocalStorage() {
            localStorage.setItem('emotionRecords', JSON.stringify(records));
        }

        // 화면 렌더링 함수
        function renderRecords() {
            const recordList = document.getElementById('recordList');
            
            if (records.length === 0) {
                recordList.innerHTML = `<p class="text-center text-gray-400 py-10">아직 기록이 없습니다.</p>`;
                return;
            }

            recordList.innerHTML = records.map(record => `
                <div class="record-card bg-white p-4 rounded-xl shadow-sm border border-gray-100 flex items-center justify-between">
                    <div class="flex items-center space-x-4">
                        <span class="text-3xl">${record.emoji}</span>
                        <div>
                            <p class="text-gray-800 font-medium">${record.text}</p>
                            <p class="text-xs text-gray-400 mt-1">${record.time}</p>
                        </div>
                    </div>
                    <button onclick="deleteRecord(${record.id})" class="text-red-400 hover:text-red-600 p-2 transition-colors">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                        </svg>
                    </button>
                </div>
            `).join('');
        }
    </script>
</body>
</html>